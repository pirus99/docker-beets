# Container configuration
CONTAINER_NAME=beets
RESTART_POLICY=unless-stopped

# User and timezone settings
PUID=1000
PGID=1000
TZ=Europe/Berlin

# SSH configuration
SSH_PASSWORD=changeme
SSH_PORT=2222

# Volume paths
CONFIG_PATH=./config
MUSIC_PATH=./music
DOWNLOADS_PATH=./downloads

# Port mappings
BEETS_WEB_PORT=8337
